{
    "kuin.cpp": {
        "filetype": "tooheavy"
    },
    "*.fs": {
        "filetype": "fsharp"
    },
    "*.fsx": {
        "filetype": "fsharp"
    },
    "colorscheme": "garro",
    "ft:kuin": {
        "commenttype": "; %s"
    },
    "ft:nim": {
        "tabsize": 2
    },
    "hlsearch": true,
    "lsp.server": "ocaml=ocaml-lsp-server,fsharp=fsautocomplete",
    "softwrap": true,
    "statusformatl": " $(filename)($(line),$(col)) $(percentage)% $(modified)",
    "statusformatr": "| $(opt:fileformat) | $(opt:encoding) | $(opt:filetype) ",
    "tabstospaces": true
}
